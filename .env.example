PROJECT_NAME=knowledge-graph-mvp

# Django / app
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
# (production refuses keys under 50 characters or with a dev prefix)
DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,django
DJANGO_HOST=api.localhost
DJANGO_GUNICORN_WORKERS=2
# Comma-separated scheme://host origins allowed to POST with session auth,
# e.g. https://api.example.com — required once served over HTTPS.
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_LOG_LEVEL=INFO
# HTTPS hardening (only applied when DJANGO_DEBUG=false):
# DJANGO_SECURE_SSL_REDIRECT=true
# DJANGO_SECURE_HSTS_SECONDS=2592000
# DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=false
# Postgres connections are reused for this many seconds (0 = per-request).
DJANGO_DB_CONN_MAX_AGE=60
# Direct localhost port added by the development Compose overlay.
DJANGO_DEV_HOST_PORT=8000

# OpenRouter is used by the backend to call hosted models.
OPENROUTER_API_KEY=replace-me
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4.1-mini
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=Client Knowledge Graph MVP
OPENROUTER_REQUEST_TIMEOUT_SECONDS=60

# Backend API
DRIVE_ROOTS_THROTTLE_RATE=30/hour
DRIVE_SYNC_THROTTLE_RATE=10/hour

# PostgreSQL
POSTGRES_DB=knowledge_graph
POSTGRES_USER=kg_user
POSTGRES_PASSWORD=change-this-postgres-password
POSTGRES_HOST_PORT=15432
DATABASE_URL=postgres://kg_user:change-this-postgres-password@postgres:5432/knowledge_graph

# Redis / Celery
REDIS_HOST_PORT=16379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Neo4j
NEO4J_HTTP_HOST_PORT=17474
NEO4J_BOLT_HOST_PORT=17687
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-this-neo4j-password
NEO4J_AUTH=neo4j/change-this-neo4j-password
NEO4J_HEAP_INITIAL=512m
NEO4J_HEAP_MAX=1G
# Container ceiling for heap, page cache, and JVM overhead combined.
NEO4J_MEMORY_LIMIT=2G

# SpiceDB
SPICEDB_GRPC_HOST_PORT=15051
SPICEDB_HTTP_HOST_PORT=18443
SPICEDB_GRPC_PRESHARED_KEY=change-this-spicedb-key
SPICEDB_GRPC_URL=spicedb:50051
# Outside development either enable TLS or explicitly acknowledge a
# private-network deployment; plaintext gRPC exposes the preshared key.
SPICEDB_GRPC_TLS=false
SPICEDB_GRPC_ALLOW_INSECURE=false
SPICEDB_REQUEST_TIMEOUT_SECONDS=10
SPICEDB_BATCH_SIZE=500
PERMISSION_SYNC_THROTTLE_RATE=10/hour
QUERY_THROTTLE_RATE=60/hour
PERMISSION_SYNC_INTERVAL_SECONDS=900
# Hard fail-closed lifetime for verified permission evidence; must exceed the
# sync interval so healthy scheduled runs refresh it before expiry.
PERMISSION_VERIFICATION_MAX_AGE_SECONDS=1800
PERMISSION_SYNC_STALE_RUN_TIMEOUT_MINUTES=120

# Open WebUI
OPEN_WEBUI_PORT=3000
OPEN_WEBUI_HOST=ai.localhost
# Public browser origin. Register WEBUI_URL + /oauth/google/callback exactly in
# the Google web OAuth client before enabling the production login flow.
WEBUI_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/google/callback
# Reuse the identity-only client above to create the Django session required
# before the separate Drive consent. Register this second callback exactly.
GOOGLE_SESSION_OAUTH_ENABLED=false
GOOGLE_SESSION_OAUTH_REDIRECT_URI=http://localhost:8000/api/session/google/callback
GOOGLE_SESSION_OAUTH_STATE_MAX_AGE_SECONDS=600
GOOGLE_SESSION_START_THROTTLE_RATE=10/hour
GOOGLE_SESSION_CALLBACK_THROTTLE_RATE=20/hour
WEBUI_SECRET_KEY=change-this-webui-secret
# Django's compatible API stays closed until both independent secrets are set.
OPEN_WEBUI_COMPATIBLE_API_ENABLED=false
OPEN_WEBUI_BACKEND_API_KEY=change-this-open-webui-backend-api-key
OPEN_WEBUI_IDENTITY_JWT_SECRET=change-this-open-webui-identity-jwt-secret
OPEN_WEBUI_IDENTITY_JWT_HEADER=X-OpenWebUI-User-Jwt
OPEN_WEBUI_IDENTITY_JWT_ISSUER=open-webui
OPEN_WEBUI_IDENTITY_JWT_MAX_LIFETIME_SECONDS=300
OPEN_WEBUI_IDENTITY_JWT_CLOCK_SKEW_SECONDS=10
OPEN_WEBUI_MODEL_ID=client-knowledge-graph
# Safe only while OPENAI_API_CONFIGS exposes the single Django-owned model.
# This lets newly registered Workspace users discover it without manual grants;
# Django still verifies identity and performs every document permission check.
OPEN_WEBUI_BYPASS_MODEL_ACCESS_CONTROL=true
OPEN_WEBUI_MODELS_THROTTLE_RATE=120/hour
OPEN_WEBUI_CHAT_THROTTLE_RATE=60/hour
# Production is Google-only. An operator may temporarily set these three flags
# to true for documented local bootstrap/recovery, then must return them to
# false and restart Open WebUI.
OPEN_WEBUI_ENABLE_LOGIN_FORM=false
OPEN_WEBUI_ENABLE_PASSWORD_AUTH=false
OPEN_WEBUI_ENABLE_PASSWORD_CHANGE_FORM=false

# Ops
DOZZLE_HOST=logs.localhost
UPTIME_KUMA_HOST=uptime.localhost
# Localhost-bound direct ports (remote access goes through Traefik + ops-auth).
TRAEFIK_DASHBOARD_HOST_PORT=8088
DOZZLE_HOST_PORT=9999
UPTIME_KUMA_HOST_PORT=3001
# Local default is admin/password. Production refuses to boot with this value
# (config/settings.py). Generate a replacement with `htpasswd -nB <user>` and
# escape every $ as $$ when pasting it here.
# settings.py recognizes this default by its salt (H6uskkkW) — if you ever
# regenerate the example hash, update the salt constant there too.
TRAEFIK_OPS_BASIC_AUTH_USERS=admin:$$apr1$$H6uskkkW$$IgXLP6ewTrSuBkTrqE8wj/

# Google Workspace / Drive
GOOGLE_WORKSPACE_DOMAIN=example.com
# application_default is preferred: local development mounts short-lived ADC
# created with service-account impersonation; Compute Engine uses its attached
# service account through the metadata server. service_account is legacy JSON
# key compatibility. oauth_dev is local-only personal-Drive development.
GOOGLE_DRIVE_AUTH_MODE=application_default
# Host path used only for local Compose. Leave both values empty on Compute
# Engine so ADC falls through to the attached service account metadata server.
GOOGLE_ADC_FILE=
GOOGLE_ADC_CONTAINER_FILE=
# Optional locally; identifies the quota/project context and suppresses ADC
# project-discovery warnings. The attached runtime may provide it instead.
GOOGLE_CLOUD_PROJECT=
# Legacy reusable-key mode only. Do not weaken organization policy to create it.
GOOGLE_SERVICE_ACCOUNT_FILE=/run/secrets/google-service-account.json
GOOGLE_DRIVE_DELEGATED_SUBJECT=
# Host paths for the local OAuth bootstrap. Keep the client file read-only and
# put only the refreshable token in its dedicated mode-0700 directory; Compose
# mounts that directory read/write for atomic token replacement.
GOOGLE_OAUTH_CLIENT_SECRET_FILE=/absolute/path/to/google-oauth-client.json
GOOGLE_OAUTH_TOKEN_DIR=/absolute/path/to/google-oauth-token-store
GOOGLE_OAUTH_TOKEN_FILE=/absolute/path/to/google-oauth-token-store/google-oauth-token.json
# ADR-015 starts in legacy delegated mode so existing deployments are not
# silently cut over. Switch only after the cutover deny/invalidate workflow.
GOOGLE_PERMISSION_AUTHORITY=delegated_acl
# Separate Django web OAuth client for per-user Drive metadata checks. These
# host paths are mounted read-only at /run/secrets in every Django process.
GOOGLE_USER_OAUTH_CLIENT_ID=
GOOGLE_USER_OAUTH_CLIENT_SECRET_FILE=/absolute/path/to/google-user-oauth-client.json
GOOGLE_USER_OAUTH_REDIRECT_URI=https://api.example.com/api/drive/oauth/callback
GOOGLE_USER_OAUTH_ALLOWED_DOMAIN=example.com
# A JSON keyring with active_version and 32-byte urlsafe-base64 Fernet keys.
# Keep this distinct from every other secret and under documented key custody.
GOOGLE_USER_TOKEN_ENCRYPTION_KEY_FILE=/absolute/path/to/google-user-token-keyring.json
# Pilot bounds: max age must exceed the refresh interval and cannot exceed one day.
GOOGLE_USER_VISIBILITY_SYNC_INTERVAL_SECONDS=900
GOOGLE_USER_VISIBILITY_MAX_AGE_SECONDS=1800
GOOGLE_USER_VISIBILITY_MAX_USERS=10
GOOGLE_USER_VISIBILITY_MAX_DOCUMENTS=1000
GOOGLE_USER_VISIBILITY_BATCH_SIZE=100
GOOGLE_USER_VISIBILITY_STALE_RUN_TIMEOUT_MINUTES=120
# Phase 7 freshness monitor. The warning window and heartbeat deadline must
# both leave time to alert before the evidence lifetime above expires.
FRESHNESS_MONITOR_INTERVAL_SECONDS=60
FRESHNESS_WARN_REMAINING_FRACTION=0.4
FRESHNESS_HEARTBEAT_MAX_AGE_SECONDS=180
# Required outside development. Configure the same value as an Authorization:
# Bearer header in the private Uptime Kuma freshness monitor; never commit it.
FRESHNESS_MONITOR_BEARER_KEY=
# Short-lived, session-bound, single-use callback state.
GOOGLE_USER_OAUTH_STATE_MAX_AGE_SECONDS=600
DRIVE_OAUTH_START_THROTTLE_RATE=10/hour
DRIVE_OAUTH_CALLBACK_THROTTLE_RATE=20/hour
DRIVE_OAUTH_STATUS_THROTTLE_RATE=120/hour
DRIVE_OAUTH_DISCONNECT_THROTTLE_RATE=10/hour
DRIVE_VISIBILITY_SYNC_THROTTLE_RATE=10/hour
# Valid values: folder | shared_drive (anything else fails at startup)
GOOGLE_DRIVE_SCOPE_TYPE=folder
GOOGLE_DRIVE_ROOT_ID=replace-me
GOOGLE_SHARED_DRIVE_ID=

# Graph extraction engine (ADR-010)
# Valid values: paragraph | neo4j_graphrag (anything else fails at startup).
# neo4j_graphrag requires OPENROUTER_API_KEY and GRAPH_EXTRACTION_MODEL.
GRAPH_EXTRACTION_ENGINE=paragraph
# OpenRouter model slug, e.g. anthropic/claude-sonnet-4.5
GRAPH_EXTRACTION_MODEL=
# Maximum text sent to the extraction engine at once. Oversized paragraphs and
# CSV rows are split with overlap before any LLM call.
GRAPH_EXTRACTION_CHUNK_MAX_CHARS=12000
GRAPH_EXTRACTION_CHUNK_OVERLAP_CHARS=1000
# Concurrent per-chunk LLM calls within one document's extraction.
GRAPH_EXTRACTION_MAX_CONCURRENT_LLM_CALLS=4

# Graph extraction recovery: reset extractions a dead worker left RUNNING,
# cap sync-driven retries per content version, and only requeue a PENDING
# document once its task message is plainly gone.
GRAPH_EXTRACTION_STALE_RUNNING_TIMEOUT_MINUTES=60
GRAPH_EXTRACTION_MAX_SYNC_ATTEMPTS=5
GRAPH_EXTRACTION_PENDING_REQUEUE_AFTER_MINUTES=15

# Neo4j chunk vector index
GRAPH_CHUNK_VECTOR_INDEX_NAME=chunk_embedding_vector
GRAPH_CHUNK_EMBEDDING_DIMENSIONS=1536
GRAPH_CHUNK_VECTOR_SIMILARITY=cosine
# Production chunk/query embeddings. Keep disabled until the OpenRouter key is
# configured; enabling this re-embeds content only on extraction or an explicit
# graph_reindex_embeddings run, never on permission-only changes.
GRAPH_EMBEDDING_PROVIDER=none
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
GRAPH_EMBEDDING_BATCH_SIZE=64

# Permission-safe answer synthesis. Enable only after guarded vector retrieval
# is configured and validated for the deployment.
QUERY_ANSWER_PROVIDER=extractive
QUERY_CONTEXT_MAX_CHARS=12000
QUERY_ANSWER_MAX_TOKENS=800
QUERY_RETRIEVAL_LIMIT=5
QUERY_VECTOR_MIN_SCORE=0.45
