#!/usr/bin/env bash
# scripts/hooks/pre-commit
#
# Offline senior-engineer pre-commit review.
# Runs automatically before every commit. Blocks commits with critical issues.
#
# Environment overrides:
#   SKIP_REVIEW=1      — skip entirely (emergency only, avoid)
#   SKIP_TESTS=1       — skip pytest (faster, use when tests already passed)
#   REVIEW_BLOCK=0     — warn but never block (useful during initial setup)

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
BACKEND_DIR="$REPO_ROOT/apps/backend"
REVIEW_FILE="$REPO_ROOT/REVIEW.md"
TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

# ─── Skip flags ─────────────────────────────────────────────────────────────

if [ "${SKIP_REVIEW:-0}" = "1" ]; then
  echo "⚠️  SKIP_REVIEW=1 set. Skipping pre-commit review."
  exit 0
fi

# ─── Colour helpers ──────────────────────────────────────────────────────────

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

section()  { echo -e "\n${CYAN}${BOLD}── $1 ──${RESET}"; }
pass()     { echo -e "  ${GREEN}✅ $1${RESET}"; }
warn()     { echo -e "  ${YELLOW}⚠️  $1${RESET}"; }
fail()     { echo -e "  ${RED}❌ $1${RESET}"; }
info()     { echo -e "     $1"; }

# ─── State ───────────────────────────────────────────────────────────────────

CRITICAL_ISSUES=()
WARNING_ISSUES=()
GOOD_NOTES=()

add_critical() { CRITICAL_ISSUES+=("$1"); fail "$1"; }
add_warning()  { WARNING_ISSUES+=("$1");  warn "$1"; }
add_good()     { GOOD_NOTES+=("$1");      pass "$1"; }

# ─── Get staged diff ─────────────────────────────────────────────────────────

STAGED_DIFF=$(git diff --cached 2>/dev/null || true)
STAGED_FILES=$(git diff --cached --name-only 2>/dev/null || true)
STAGED_PY_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null | grep '\.py$' || true)

if [ -z "$STAGED_DIFF" ]; then
  echo "Nothing staged. Nothing to review."
  exit 0
fi

echo ""
echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
echo -e "${BOLD}  🔍 Pre-commit Senior Engineer Review${RESET}"
echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
echo -e "  ${CYAN}Time:${RESET}  $TIMESTAMP"
echo -e "  ${CYAN}Files:${RESET} $(echo "$STAGED_FILES" | wc -l | tr -d ' ') staged"

# ─── Check 1: Lint ───────────────────────────────────────────────────────────

section "Python Lint (Ruff)"

if [ -z "$STAGED_PY_FILES" ]; then
  info "No Python files staged — skipping lint."
else
  if [ -d "$BACKEND_DIR" ]; then
    cd "$BACKEND_DIR"

    if uv run ruff check $STAGED_PY_FILES 2>&1; then
      add_good "Ruff lint passed"
    else
      add_critical "Ruff lint failed — run: make lint"
    fi

    if uv run ruff format --check $STAGED_PY_FILES 2>&1; then
      add_good "Ruff format passed"
    else
      add_warning "Ruff format issues — run: make format"
    fi

    cd "$REPO_ROOT"
  else
    info "Backend dir not found — skipping lint."
  fi
fi

# ─── Check 2: Secret / credential patterns ───────────────────────────────────

section "Secret & Credential Scan"

SECRET_PATTERNS=(
  'password\s*=\s*["\x27][^"\x27${}]'
  'secret\s*=\s*["\x27][^"\x27${}]'
  'api_key\s*=\s*["\x27][^"\x27${}]'
  'token\s*=\s*["\x27][^"\x27${}]'
  'OPENROUTER_API_KEY\s*=\s*["\x27](?!replace)'
  'NEO4J_PASSWORD\s*=\s*["\x27](?!change)'
  'POSTGRES_PASSWORD\s*=\s*["\x27](?!change)'
  'preshared_key\s*=\s*["\x27][^"\x27${}]'
)

SECRET_FOUND=false
for pattern in "${SECRET_PATTERNS[@]}"; do
  if echo "$STAGED_DIFF" | grep -qiP "$pattern" 2>/dev/null; then
    add_critical "Possible hardcoded secret matching pattern: $pattern"
    SECRET_FOUND=true
  fi
done

if [ "$SECRET_FOUND" = false ]; then
  add_good "No hardcoded secrets detected"
fi

# ─── Check 3: DEBUG mode ─────────────────────────────────────────────────────

section "DEBUG Mode Check"

if echo "$STAGED_DIFF" | grep -qP '^\+\s*DEBUG\s*=\s*True' 2>/dev/null; then
  add_critical "DEBUG = True being committed — must not reach production"
else
  add_good "No DEBUG=True in staged changes"
fi

# ─── Check 4: Stack traces in responses ──────────────────────────────────────

section "Stack Trace / Error Leak Check"

if echo "$STAGED_DIFF" | grep -qP '^\+.*traceback|^\+.*exc_info=True.*Response|^\+.*str\(e\).*Response|^\+.*exception.*message.*Response' 2>/dev/null; then
  add_warning "Possible stack trace or raw exception message in an API response — verify error is controlled"
fi

if echo "$STAGED_DIFF" | grep -qP '^\+.*raise.*Http|^\+.*return.*Response.*str\(e\)' 2>/dev/null; then
  add_warning "Raw exception string may be leaking in a Response — use a controlled error label instead"
else
  add_good "No obvious error leak patterns found"
fi

# ─── Check 5: AllowAny on non-utility endpoints ──────────────────────────────

section "Permission Class Check"

ALLOW_ANY_LINES=$(echo "$STAGED_DIFF" | grep -nP '^\+.*AllowAny' 2>/dev/null || true)
if [ -n "$ALLOW_ANY_LINES" ]; then
  while IFS= read -r line; do
    FILE_HINT=$(echo "$STAGED_FILES" | grep 'views.py' | head -1 || echo "a views file")
    # Only warn if it's not in health or core (those legitimately use AllowAny)
    if echo "$FILE_HINT" | grep -qvP 'health|core'; then
      add_warning "AllowAny permission class added in $FILE_HINT — confirm this endpoint should be public"
    else
      add_good "AllowAny on health/smoke endpoint (expected)"
    fi
  done <<< "$ALLOW_ANY_LINES"
fi

# ─── Check 6: Raw SQL ────────────────────────────────────────────────────────

section "Raw SQL Safety Check"

if echo "$STAGED_DIFF" | grep -qP '^\+.*cursor\(\)\.execute\(' 2>/dev/null; then
  if echo "$STAGED_DIFF" | grep -qP '^\+.*cursor\(\)\.execute\(.*["\x27].*%s|^\+.*cursor\(\)\.execute\(.*["\x27].*\?' 2>/dev/null; then
    add_good "Raw SQL uses parameterized query (looks safe)"
  else
    add_critical "Raw SQL without clear parameterization — use parameterized queries only"
  fi
fi

# ─── Check 7: Neo4j provenance ───────────────────────────────────────────────

section "Neo4j Provenance Check"

NEO4J_WRITES=$(echo "$STAGED_DIFF" | grep -P '^\+.*session\.run|^\+.*tx\.run|^\+.*CREATE|^\+.*MERGE' 2>/dev/null || true)
if [ -n "$NEO4J_WRITES" ]; then
  if echo "$STAGED_DIFF" | grep -qP 'source_document|source_chunk|extraction_run|created_at' 2>/dev/null; then
    add_good "Neo4j write includes provenance fields"
  else
    add_warning "Neo4j write detected but no provenance fields (source_document_id, extraction_run_id, etc.) visible in diff — verify provenance is set"
  fi
fi

# ─── Check 8: SpiceDB bypass ─────────────────────────────────────────────────

section "SpiceDB / Permission Bypass Check"

if echo "$STAGED_DIFF" | grep -qP '^\+.*def.*retrieve|^\+.*def.*query|^\+.*def.*search' 2>/dev/null; then
  if echo "$STAGED_DIFF" | grep -qP 'spicedb|allowed_documents|check_permission|visible_docs' 2>/dev/null; then
    add_good "Retrieval/query function includes SpiceDB or permission check reference"
  else
    add_warning "New retrieval or query function added without visible SpiceDB check — confirm permission filtering is applied"
  fi
fi

# ─── Check 9: print() in production code ─────────────────────────────────────

section "Debug Print Check"

PRINT_IN_PROD=$(echo "$STAGED_DIFF" | grep -P '^\+\s*print\(' 2>/dev/null | \
  grep -vP 'test_|tests\.py|conftest' || true)
if [ -n "$PRINT_IN_PROD" ]; then
  add_warning "print() statement in non-test code — use logging instead"
  info "Affected lines: $(echo "$PRINT_IN_PROD" | wc -l)"
else
  add_good "No print() in production code"
fi

# ─── Check 10: Celery task safety ────────────────────────────────────────────

section "Celery Task Safety"

NEW_TASKS=$(echo "$STAGED_DIFF" | grep -P '^\+.*@.*task|^\+.*@shared_task' 2>/dev/null || true)
if [ -n "$NEW_TASKS" ]; then
  if echo "$STAGED_DIFF" | grep -qP '^\+.*def.*task.*\(.*self.*\)|bind=True' 2>/dev/null; then
    info "Bound task found — ensure retry logic is correct"
  fi
  if echo "$STAGED_DIFF" | grep -qP '^\+.*\.objects\.|^\+.*Model\.' 2>/dev/null; then
    # Check if Django model instances are being passed (they shouldn't be)
    TASK_ARGS=$(echo "$STAGED_DIFF" | grep -P '^\+.*\.delay\(|^\+.*\.apply_async\(' 2>/dev/null || true)
    if echo "$TASK_ARGS" | grep -qP '\.(objects|pk|id)\b' 2>/dev/null; then
      add_warning "Possible Django model instance passed to Celery task — pass primitive IDs only"
    else
      add_good "Celery task arguments appear primitive"
    fi
  fi
fi

# ─── Check 11: Compose file validation ───────────────────────────────────────

section "Docker Compose Validation"

COMPOSE_CHANGED=$(echo "$STAGED_FILES" | grep -P 'compose.*\.yml$' || true)
if [ -n "$COMPOSE_CHANGED" ]; then
  if docker compose -f infra/compose.infrastructure.yml -f infra/compose.app.yml config > /dev/null 2>&1; then
    add_good "Combined Compose config is valid"
  else
    add_critical "Docker Compose config is invalid — run: make config"
  fi
else
  add_good "No Compose files changed"
fi

# ─── Check 12: Tests ─────────────────────────────────────────────────────────

section "Test Suite"

if [ "${SKIP_TESTS:-0}" = "1" ]; then
  add_warning "Tests skipped (SKIP_TESTS=1). Run: make test"
elif [ -d "$BACKEND_DIR" ] && [ -n "$STAGED_PY_FILES" ]; then
  cd "$BACKEND_DIR"
  if uv run pytest --tb=short -q 2>&1; then
    add_good "All tests passed"
  else
    add_critical "Tests failed — fix before committing"
  fi
  cd "$REPO_ROOT"
else
  info "No Python files staged or backend not found — skipping tests."
fi

# ─── Summary ─────────────────────────────────────────────────────────────────

echo ""
echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
echo -e "${BOLD}  Review Summary${RESET}"
echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
echo -e "  ${GREEN}✅ Passed:${RESET}   ${#GOOD_NOTES[@]} checks"
echo -e "  ${YELLOW}⚠️  Warnings:${RESET} ${#WARNING_ISSUES[@]} items"
echo -e "  ${RED}❌ Critical:${RESET} ${#CRITICAL_ISSUES[@]} items"

# ─── Write REVIEW.md ─────────────────────────────────────────────────────────

{
  echo "<!-- AUTO-GENERATED by pre-commit hook — read before next task -->"
  echo ""
  echo "# Pre-Commit Senior Engineer Review"
  echo ""
  echo "**Generated:** $TIMESTAMP"
  echo "**Status:** $([ ${#CRITICAL_ISSUES[@]} -gt 0 ] && echo '❌ COMMIT BLOCKED' || ([ ${#WARNING_ISSUES[@]} -gt 0 ] && echo '⚠️ COMMITTED WITH WARNINGS' || echo '✅ CLEAN'))"
  echo ""

  if [ ${#CRITICAL_ISSUES[@]} -gt 0 ]; then
    echo "## ❌ Critical — Must Fix"
    echo ""
    for issue in "${CRITICAL_ISSUES[@]}"; do
      echo "- $issue"
    done
    echo ""
  fi

  if [ ${#WARNING_ISSUES[@]} -gt 0 ]; then
    echo "## ⚠️ Warnings — Should Fix"
    echo ""
    for issue in "${WARNING_ISSUES[@]}"; do
      echo "- $issue"
    done
    echo ""
  fi

  if [ ${#GOOD_NOTES[@]} -gt 0 ]; then
    echo "## ✅ Passed"
    echo ""
    for note in "${GOOD_NOTES[@]}"; do
      echo "- $note"
    done
    echo ""
  fi

  echo "## Staged Files"
  echo '```'
  echo "$STAGED_FILES"
  echo '```'
  echo ""

  if [ ${#CRITICAL_ISSUES[@]} -gt 0 ]; then
    echo "## Codex Action Items"
    echo ""
    echo "The commit was **blocked**. Fix the following before retrying:"
    echo ""
    N=1
    for issue in "${CRITICAL_ISSUES[@]}"; do
      echo "$N. Fix: $issue"
      N=$((N+1))
    done
    for issue in "${WARNING_ISSUES[@]}"; do
      echo "$N. Address (warning): $issue"
      N=$((N+1))
    done
  elif [ ${#WARNING_ISSUES[@]} -gt 0 ]; then
    echo "## Codex Action Items"
    echo ""
    echo "Commit passed but address these in the next task:"
    echo ""
    N=1
    for issue in "${WARNING_ISSUES[@]}"; do
      echo "$N. $issue"
      N=$((N+1))
    done
  fi
} > "$REVIEW_FILE"

echo -e "  ${CYAN}REVIEW.md${RESET} written to repo root."

# ─── Block or pass ───────────────────────────────────────────────────────────

if [ ${#CRITICAL_ISSUES[@]} -gt 0 ] && [ "${REVIEW_BLOCK:-1}" != "0" ]; then
  echo ""
  echo -e "  ${RED}${BOLD}Commit BLOCKED.${RESET} Fix critical issues above, then retry."
  echo -e "  To skip in an emergency: ${YELLOW}SKIP_REVIEW=1 git commit ...${RESET}"
  echo ""
  exit 1
else
  if [ ${#CRITICAL_ISSUES[@]} -gt 0 ]; then
    echo -e "  ${YELLOW}REVIEW_BLOCK=0 set — commit allowed despite critical issues.${RESET}"
  fi
  echo ""
  echo -e "  ${GREEN}${BOLD}Commit approved.${RESET}"
  echo ""
  exit 0
fi
